{
  "name": "somestr-portfolio",
  "version": "1.0.0",
  "description": "Interactive IT and cybersecurity portfolio with static hosting and an optional hardened Node.js/Express backend",
  "main": "server.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "check": "node scripts/check-js-syntax.js",
    "test": "node --test app-utils.test.js server.test.js security-events-report.test.js static-assets.test.js",
    "security:report": "node scripts/security-events-report.js",
    "audit": "npm audit --audit-level=high"
  },
  "keywords": ["portfolio", "cybersecurity", "node", "express"],
  "author": "somestr",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "express": "^5.2.1"
  }
}

/* ============================================
   CYBER SECURITY PORTFOLIO â€” STYLE.CSS
   ============================================ */

/* ---------- Reset & Base ---------- */
*, *::before, *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

:root {
    --blue:       #5294e2;
    --blue-dim:   #3a7bd5;
    --blue-dark:  #0a1628;
    --white:      #ffffff;
    --gray:       #808080;
    --gray-dim:   #505050;
    --bg:         #000000;
    --bg2:        #080808;
    --bg-card:    rgba(255, 255, 255, 0.02);
    --border:     rgba(255, 255, 255, 0.06);
    --border-h:   rgba(82, 148, 226, 0.35);
    --text:       #c8c8c8;
    --text-dim:   #606060;
    --font-mono:  'Courier New', Courier, monospace;
    --nav-h:      48px;
    --transition: 0.2s ease;
    --green:      #5294e2;
    --green-dim:  #3a7bd5;
    --green-dark: #0a1628;
    --cyan:       #5294e2;
    --red:        #5294e2;
    --yellow:     #5294e2;
    --orange:     #5294e2;
}

html {
    scroll-behavior: smooth;
    scrollbar-width: thin;
    scrollbar-color: var(--green-dim) var(--bg);
}

::-webkit-scrollbar          { width: 6px; }
::-webkit-scrollbar-track    { background: var(--bg); }
::-webkit-scrollbar-thumb    { background: var(--green-dim); border-radius: 3px; }

body {
    background: #000;
    color: var(--text);
    font-family: var(--font-mono);
    overflow-x: hidden;
    min-height: 100vh;
}

/* Selection */
::selection {
    background: var(--blue);
    color: #000;
}

::-moz-selection {
    background: var(--blue);
    color: #000;
}

a { color: var(--blue); text-decoration: none; transition: color 0.15s; }
a:hover { color: #fff; }
ul { list-style: none; }

/* ---------- Matrix Canvas ---------- */
#matrix-canvas {
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 100%;
    z-index: 0;
    opacity: 0.09;
    pointer-events: none;
}

/* ---------- Scanlines ---------- */
.scanlines {
    display: block;
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 100%;
    z-index: 9998;
    pointer-events: none;
    background: repeating-linear-gradient(
        0deg,
        transparent,
        transparent 2px,
        rgba(0, 0, 0, 0.04) 2px,
        rgba(0, 0, 0, 0.04) 4px
    );
    opacity: 0.5;
}

/* ---------- Vignette ---------- */
.vignette {
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 100%;
    z-index: 1;
    pointer-events: none;
    background: radial-gradient(
        ellipse at center,
        transparent 55%,
        rgba(0, 0, 0, 0.6) 100%
    );
}

/* ---------- Grid Background ---------- */
body::before {
    content: '';
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 100%;
    z-index: 0;
    pointer-events: none;
    background-image:
        linear-gradient(rgba(82, 148, 226, 0.015) 1px, transparent 1px),
        linear-gradient(90deg, rgba(82, 148, 226, 0.015) 1px, transparent 1px);
    background-size: 40px 40px;
}

/* ---------- Navigation ---------- */
.terminal-nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    height: var(--nav-h);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 2rem;
    background: #000;
    border-bottom: 1px solid #111;
    z-index: 1000;
    gap: 1rem;
}

.nav-logo {
    font-size: 1.1rem;
    font-weight: bold;
    color: var(--green);
    white-space: nowrap;
    min-width: 180px;
}

.bracket { color: var(--text-dim); }

.logo-text {
    color: var(--green);
    letter-spacing: 1px;
}

.nav-links {
    display: flex;
    gap: 0.2rem;
    align-items: center;
    flex-wrap: wrap;
}

.nav-link {
    color: var(--text-dim);
    font-size: 0.8rem;
    padding: 0.35rem 0.7rem;
    border: none;
    transition: color var(--transition);
    text-transform: lowercase;
    letter-spacing: 0.5px;
    position: relative;
}

.nav-link::after {
    content: '';
    position: absolute;
    bottom: 2px;
    left: 0.7rem;
    right: 0.7rem;
    height: 1px;
    background: var(--blue);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s ease;
}

.nav-link:hover::after,
.nav-link.active::after {
    transform: scaleX(1);
}

.nav-link:hover,
.nav-link.active {
    color: var(--blue);
    background: transparent;
}

.nav-right {
    display: flex;
    align-items: center;
    gap: 1rem;
    min-width: 200px;
    justify-content: flex-end;
}

/* ---------- Language Toggle ---------- */
.lang-toggle {
    display: flex;
    align-items: center;
    gap: 4px;
    cursor: pointer;
    border: none;
    padding: 3px 0;
    font-size: 0.75rem;
    user-select: none;
}

.lang-toggle:hover .lang-opt { color: var(--text); }

.lang-opt {
    color: var(--text-dim);
    transition: color var(--transition);
    font-weight: bold;
    letter-spacing: 1px;
}

.lang-opt.active { color: var(--green); }

.lang-sep { color: var(--border); }

/* ---------- Status ---------- */
.nav-status {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.7rem;
    color: var(--text-dim);
    white-space: nowrap;
}

.status-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: #5294e2;
    animation: pulse 2s infinite;
}

@keyframes pulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.4; }
}

.cursor-blink {
    animation: blink 1s step-end infinite;
    color: var(--green);
}

@keyframes blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
}

/* ---------- Hero ---------- */
.hero {
    position: relative;
    z-index: 2;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: calc(var(--nav-h) + 2rem) 2rem 4rem;
}

.hero-content {
    width: 100%;
    max-width: 800px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
}

/* ---------- Terminal Window ---------- */
.terminal-window {
    width: 100%;
    border: none;
    background: transparent;
    overflow: visible;
}

.terminal-titlebar {
    display: none;
}

.tb-btn { display: none; }
.tb-close, .tb-min, .tb-max { display: none; }

.tb-title { display: none; }
.tb-cursor { display: none; }

.terminal-body {
    padding: 0;
    min-height: 0;
    font-size: 0.92rem;
    line-height: 1.75;
}

.term-line { display: flex; align-items: center; gap: 0.5rem; }

.prompt { color: var(--green); font-weight: bold; flex-shrink: 0; }

.cmd { color: var(--cyan); }

.term-output { padding: 0.5rem 0 0.5rem 1rem; }

.output-block p { line-height: 2; }

.key { color: var(--text-dim); min-width: 80px; display: inline-block; }

.val { color: var(--text); }

.success { color: var(--blue) !important; }
.warn    { color: var(--text-dim) !important; }
.info    { color: var(--blue) !important; }

.progress-bar-wrap {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: 0.5rem;
}

.progress-bar {
    height: 3px;
    width: 200px;
    background: #111;
    border: none;
    overflow: hidden;
    position: relative;
}

.progress-bar::after {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: var(--pct, 0%);
    background: var(--blue);
    transition: width 0.05s linear;
}

.progress-pct { color: var(--green); font-size: 0.8rem; }

.blink-cursor { color: var(--green); animation: blink 1s step-end infinite; }

/* ---------- Hero CTA ---------- */
.hero-cta {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
    justify-content: center;
}

.btn-primary, .btn-secondary {
    padding: 0.6rem 1.5rem;
    border: none;
    font-family: var(--font-mono);
    font-size: 0.9rem;
    font-weight: bold;
    cursor: pointer;
    transition: color var(--transition);
    letter-spacing: 1px;
    background: transparent;
}

.btn-primary {
    color: var(--blue);
}

.btn-primary::before {
    content: '> ';
}

.btn-primary:hover {
    color: #fff;
}

.btn-secondary {
    color: var(--text-dim);
}

.btn-secondary::before {
    content: '> ';
    color: var(--blue);
}

.btn-secondary:hover {
    color: var(--blue);
}

/* ---------- Scroll Hint ---------- */
.scroll-hint {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.7rem;
    color: var(--text-dim);
}

.scroll-arrow { font-size: 1rem; }

/* ---------- Sections ---------- */
.section {
    position: relative;
    z-index: 2;
    padding: 5rem 0;
}

.section-dark { background: transparent; }

.container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem;
}

/* Section Divider — ASCII line between sections */
.section-divider {
    text-align: center;
    color: #1a1a1a;
    font-size: 0.6rem;
    line-height: 1;
    padding: 0;
    user-select: none;
    overflow: hidden;
    white-space: nowrap;
    position: relative;
    z-index: 2;
}

.section-divider::before {
    content: '';
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 200px;
    height: 20px;
    background: radial-gradient(ellipse, rgba(82,148,226,0.06) 0%, transparent 70%);
    pointer-events: none;
}

.section-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2.5rem;
    position: relative;
}

.section-header::before {
    content: '';
    position: absolute;
    left: -2rem;
    top: 50%;
    transform: translateY(-50%);
    width: 120px;
    height: 40px;
    background: radial-gradient(ellipse, rgba(82,148,226,0.08) 0%, transparent 70%);
    pointer-events: none;
    z-index: -1;
}

.section-num {
    color: var(--blue);
    font-size: 0.85rem;
    opacity: 1;
}

.section-num::before {
    content: '┌──(';
    color: var(--blue);
}

.section-num::after {
    content: ')';
    color: var(--blue);
}

.section-title {
    font-size: clamp(1rem, 2.5vw, 1.3rem);
    color: var(--text);
    letter-spacing: 1px;
    white-space: nowrap;
    font-weight: normal;
}

.section-title::before {
    content: '─# ';
    color: var(--blue);
}

.section-line {
    flex: 1;
    height: 1px;
    background: #111;
}

/* Section scroll-reveal */
.section-header .section-title-text {
    display: inline;
}

.section .term-typed {
    display: inline;
    overflow: hidden;
    border-right: 2px solid var(--blue);
    animation: blink-caret 0.8s step-end infinite;
}

@keyframes blink-caret {
    0%, 100% { border-color: var(--blue); }
    50%      { border-color: transparent; }
}

.section .term-typed.done {
    border-right-color: transparent;
    animation: none;
}

/* ---------- Terminal Card ---------- */
.terminal-card {
    border: none;
    background: transparent;
    overflow: visible;
}

.terminal-card:hover {
    border-color: transparent;
}

.card-header {
    padding: 0;
    background: transparent;
    border-bottom: none;
    font-size: 0.85rem;
    color: var(--blue);
    margin-bottom: 0.6rem;
}

.card-icon { color: var(--blue); margin-right: 0.4rem; }

.card-body {
    padding: 0 0 0 1.2rem;
    line-height: 1.75;
    color: var(--text);
    font-size: 0.92rem;
}

.highlight { color: var(--green); font-weight: bold; }

/* ---------- About Grid ---------- */
.about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    align-items: start;
}

@media (max-width: 768px) {
    .about-grid { grid-template-columns: 1fr; }
}

/* ---------- Stats ---------- */
.about-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.3rem;
}

.stat-card {
    border: none;
    padding: 0.5rem 0;
    text-align: left;
    background: transparent;
}

.stat-card:hover {
    border-color: transparent;
}

.stat-num {
    display: inline;
    font-size: 1.3rem;
    font-weight: bold;
    color: var(--blue);
    margin-right: 0.5rem;
}

.stat-label {
    font-size: 0.7rem;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 1px;
}

.cert-list {
    grid-column: 1 / -1;
    border: none;
    padding: 0.5rem 0;
    background: transparent;
}

.cert-title {
    font-size: 0.75rem;
    color: var(--text-dim);
    margin-bottom: 0.6rem;
}

.cert-badge {
    display: inline-block;
    border: none;
    color: var(--blue);
    font-size: 0.8rem;
    padding: 0;
    margin: 0 1rem 0 0;
    background: transparent;
}
.cert-badge.pursuing {
    border-style: dashed;
    opacity: 0.7;
    animation: pulse-pursuing 2s ease-in-out infinite;
}
@keyframes pulse-pursuing {
    0%, 100% { opacity: 0.5; }
    50%      { opacity: 0.9; }
}

/* ---------- Skills Grid ---------- */
.skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
}

.skill-category {
    border: none;
    padding: 0;
    background: transparent;
}

.skill-cat-title {
    font-size: 1rem;
    color: var(--blue);
    margin-bottom: 1rem;
    padding-bottom: 0;
    border-bottom: none;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.cat-icon { font-size: 1rem; }

.skill-item { margin-bottom: 1rem; }

.skill-info {
    display: flex;
    justify-content: space-between;
    font-size: 0.82rem;
    color: var(--text);
    margin-bottom: 0.3rem;
}

.skill-pct { color: var(--blue); font-family: var(--font-mono); }

.skill-bar {
    height: 6px;
    background: #0a0a0a;
    border-radius: 0;
    overflow: hidden;
    position: relative;
}

.skill-bar::before {
    content: '';
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
        90deg,
        transparent,
        transparent 3px,
        rgba(0,0,0,0.5) 3px,
        rgba(0,0,0,0.5) 4px
    );
    z-index: 1;
}

.skill-fill {
    height: 100%;
    width: 0;
    background: linear-gradient(90deg, var(--blue-dim), var(--blue));
    border-radius: 0;
    transition: width 1.2s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
}

.tools-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
}

.tool-tag {
    border: none;
    color: var(--text);
    font-size: 0.82rem;
    padding: 0;
    margin: 0 0.5rem 0.3rem 0;
    background: transparent;
    cursor: default;
}

.tool-tag::before {
    content: '> ';
    color: var(--blue);
}

.tool-tag:hover {
    color: #fff;
}

/* ---------- Projects Grid ---------- */
.projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(310px, 1fr));
    gap: 1.5rem;
}

.project-card {
    border: none;
    border-left: 2px solid #1a1a1a;
    padding: 0.3rem 0 1.5rem 1.2rem;
    background: transparent;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    transition: border-color 0.3s ease;
}

.project-card:hover {
    border-left-color: var(--blue);
}

.project-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.project-icon { font-size: 1.5rem; }

.project-links { display: flex; gap: 0.5rem; }

.proj-link {
    font-size: 0.75rem;
    color: var(--text-dim);
    border: none;
    padding: 0;
    transition: color var(--transition);
}

.proj-link:hover {
    color: var(--blue);
}

.project-title {
    font-size: 1.05rem;
    color: var(--blue);
    letter-spacing: 1px;
}

.project-desc {
    font-size: 0.82rem;
    color: var(--text-dim);
    line-height: 1.7;
    flex: 1;
}

.project-tags { display: flex; flex-wrap: wrap; gap: 0.4rem; }

.p-tag {
    font-size: 0.75rem;
    color: var(--text-dim);
    border: none;
    padding: 0;
    margin-right: 0.5rem;
    background: transparent;
}

.p-tag::before {
    content: '#';
    color: var(--blue);
}

.project-severity {
    font-size: 0.75rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    padding-top: 0.3rem;
    border-top: none;
}

.sev-label { color: var(--text-dim); }

.sev.critical { color: #fff; font-weight: bold; }
.sev.high     { color: var(--blue); }
.sev.medium   { color: var(--text-dim); }

/* ---------- Contact ---------- */
.contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    align-items: start;
}

@media (max-width: 768px) {
    .contact-grid { grid-template-columns: 1fr; }
}

.contact-json { font-size: 0.85rem; line-height: 2; }

.json-brace  { color: var(--text-dim); }
.json-indent { padding-left: 1.5rem; }
.json-key    { color: var(--blue); }
.json-val    { color: #fff; }
.json-val a  {
    color: #fff;
    text-decoration: none;
    border-bottom: 1px solid #333;
    transition: border-color 0.2s, color 0.2s;
}
.json-val a:hover {
    color: var(--blue);
    border-bottom-color: var(--blue);
}

/* ---------- Form ---------- */
.form-group { margin-bottom: 1.2rem; }

.form-label {
    display: block;
    font-size: 0.78rem;
    color: var(--text-dim);
    margin-bottom: 0.4rem;
}

.prompt-mini { color: var(--green); margin-right: 0.3rem; }

.form-input {
    width: 100%;
    background: transparent;
    border: none;
    border-bottom: 1px solid #222;
    padding: 0.5rem 0;
    color: var(--text);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    outline: none;
    transition: border-color var(--transition);
}

.form-input:focus {
    border-bottom-color: var(--blue);
}

.form-input::placeholder { color: var(--text-dim); }

.form-textarea {
    min-height: 120px;
    resize: vertical;
}

.btn-submit {
    width: 100%;
    padding: 0.75rem;
    background: transparent;
    border: none;
    border-bottom: 1px solid var(--blue);
    color: var(--blue);
    font-family: var(--font-mono);
    font-size: 0.9rem;
    font-weight: bold;
    letter-spacing: 1px;
    cursor: pointer;
    transition: color var(--transition);
    margin-top: 0.5rem;
    text-align: left;
}

.btn-submit::before {
    content: '> ';
}

.btn-submit:hover {
    color: #fff;
}

.btn-submit:disabled {
    opacity: 0.5;
    cursor: not-allowed;
}

.form-status {
    margin-top: 0.8rem;
    padding: 0.6rem 0;
    font-size: 0.82rem;
    border: none;
}

.form-status.success { color: var(--blue); }
.form-status.error   { color: #ff5555; }

/* ---------- Footer ---------- */
.footer {
    position: relative;
    z-index: 2;
    border-top: 1px solid #111;
    padding: 2rem;
    text-align: center;
    background: transparent;
}

.footer-text {
    font-size: 0.8rem;
    color: var(--text-dim);
    margin-bottom: 0.5rem;
}

.footer-copy {
    font-size: 0.7rem;
    color: var(--text-dim);
    opacity: 0.6;
}

.footer-ascii {
    margin-top: 1.5rem;
    color: var(--blue);
    opacity: 0.15;
    font-size: 0.6rem;
    line-height: 1.4;
}

/* ---------- Animations ---------- */
.fade-in {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.7s ease, transform 0.7s ease;
}

.fade-in.visible {
    opacity: 1;
    transform: translateY(0);
}

/* ---------- Responsive ---------- */
@media (max-width: 768px) {
    .terminal-nav {
        padding: 0 1rem;
        flex-wrap: wrap;
        height: auto;
        padding-top: 0.5rem;
        padding-bottom: 0.5rem;
        gap: 0.5rem;
    }

    .nav-links { gap: 0.1rem; }
    .nav-link  { font-size: 0.72rem; padding: 0.25rem 0.5rem; }

    .nav-right { min-width: unset; }

    .skills-grid   { grid-template-columns: 1fr; }
    .projects-grid { grid-template-columns: 1fr; }

    .about-stats { grid-template-columns: 1fr 1fr; }

    .hero { padding-top: 100px; }
}

@media (max-width: 480px) {
    .nav-status { display: none; }
    .hero-cta   { flex-direction: column; align-items: center; }
    .btn-primary, .btn-secondary { width: 100%; text-align: center; }
}

/* ============================================
   ENHANCED FEATURES â€” v3.0
   ============================================ */

/* ---------- Particle Canvas ---------- */
#particle-canvas { display: none; }

/* ---------- Terminal Intro Overlay ---------- */
.intro-overlay {
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 100%;
    background: #000;
    z-index: 99999;
    transition: opacity 0.6s ease, visibility 0.6s ease;
    cursor: default;
    overflow: hidden;
}

.intro-overlay * { cursor: default; }

.intro-overlay.hidden {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
}

/* ── Kali bare terminal screen ── */
.kali-screen {
    width: 100%;
    height: 100%;
    padding: 2rem 3rem;
    overflow-y: auto;
    font-family: 'Courier New', Courier, monospace;
    font-size: 0.92rem;
    line-height: 1.75;
    color: #c8c8c8;
    background: #000;
}

.kali-screen p {
    margin: 0;
    white-space: pre-wrap;
    word-break: break-all;
}

/* colors — ONLY blue and white on black */
.k-blue  { color: #5294e2; }
.k-white { color: #ffffff; font-weight: bold; }
.k-dim   { color: #606060; }
.k-blink { color: #5294e2; animation: blink 1s step-end infinite; }

@media (max-width: 600px) {
    .kali-screen { padding: 1rem 1.2rem; font-size: 0.78rem; }
}

/* ---------- Custom Cursor ---------- */
.custom-cursor, .cursor-trail { display: none !important; }

/* ---------- Mobile Menu Button ---------- */
.mobile-menu-btn {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    padding: 8px;
    cursor: pointer;
}

.mobile-menu-btn:hover span { background: var(--blue); }

.mobile-menu-btn span {
    display: block;
    width: 20px;
    height: 2px;
    background: var(--green);
    transition: all 0.3s ease;
}

.mobile-menu-btn.active span:nth-child(1) {
    transform: rotate(45deg) translate(5px, 5px);
}
.mobile-menu-btn.active span:nth-child(2) {
    opacity: 0;
}
.mobile-menu-btn.active span:nth-child(3) {
    transform: rotate(-45deg) translate(5px, -5px);
}

@media (max-width: 768px) {
    .mobile-menu-btn { display: flex; }

    .nav-links {
        position: fixed;
        top: var(--nav-h);
        left: 0; right: 0;
        background: #000;
        border-bottom: 1px solid #111;
        flex-direction: column;
        align-items: center;
        padding: 1rem 0;
        gap: 0.5rem;
        transform: translateY(-100%);
        opacity: 0;
        transition: transform 0.3s ease, opacity 0.3s ease;
        pointer-events: none;
        z-index: 999;
    }

    .nav-links.open {
        transform: translateY(0);
        opacity: 1;
        pointer-events: all;
    }
}

/* ---------- Timeline ---------- */
.timeline {
    position: relative;
    padding-left: 2rem;
}

.timeline::before {
    content: '';
    position: absolute;
    left: 8px;
    top: 0;
    bottom: 0;
    width: 1px;
    background: #222;
}

.timeline-item {
    position: relative;
    margin-bottom: 2rem;
    padding-left: 1.5rem;
}

.timeline-marker {
    position: absolute;
    left: -2rem;
    top: 1.2rem;
    z-index: 2;
}

.timeline-dot {
    display: block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--blue);
    border: none;
}

.timeline-item:hover .timeline-dot {
    background: #fff;
}

.timeline-title {
    color: var(--blue);
    font-size: 1rem;
    letter-spacing: 1px;
    margin-bottom: 0.3rem;
}

.timeline-company {
    color: var(--text-dim);
    font-size: 0.82rem;
    margin-bottom: 0.6rem;
}

.timeline-desc {
    color: var(--text-dim);
    font-size: 0.82rem;
    line-height: 1.7;
    margin-bottom: 0.8rem;
}

.timeline-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
}

/* ---------- Project Filters ---------- */
.project-filters {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
}

.filter-btn {
    padding: 0.4rem 1rem;
    background: transparent;
    border: none;
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    cursor: pointer;
    transition: color var(--transition);
    letter-spacing: 0.5px;
}

.filter-btn:hover,
.filter-btn.active {
    color: var(--blue);
    background: transparent;
}

.filter-btn.active::before {
    content: '[ ';
    color: var(--blue);
}

.filter-btn.active::after {
    content: ' ]';
    color: var(--blue);
}

.project-card.filter-hidden {
    display: none;
}

/* ---------- Server Status Card ---------- */
.server-status-card {
    margin-top: 1rem;
}

.server-stat {
    line-height: 2;
}

/* ---------- Back to Top ---------- */
.back-to-top {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    width: auto;
    height: auto;
    background: transparent;
    border: none;
    color: var(--blue);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1px;
    z-index: 100;
    opacity: 0;
    transform: translateY(20px);
    transition: all var(--transition);
    pointer-events: none;
}

.back-to-top.visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: all;
}

.back-to-top:hover {
    color: #fff;
}

.btt-text { font-size: 0.55rem; letter-spacing: 1px; }

/* ---------- Glitch Hover ---------- */
.glitch-hover { position: relative; }

/* ---------- Cyber Button Glow ---------- */
.cyber-btn { position: relative; }

/* ---------- Enhanced Card Hover ---------- */
.terminal-card {
    transition: none;
}

.terminal-card:hover {
    border-color: transparent;
}

/* ---------- Nav Scroll Effect ---------- */
.terminal-nav.scrolled {
    background: rgba(0, 0, 0, 0.95);
    border-bottom-color: #222;
    backdrop-filter: blur(10px);
}

/* ---------- Staggered Fade-In ---------- */
.fade-in-stagger {
    opacity: 0;
    transform: translateY(15px);
    transition: opacity 0.5s ease, transform 0.5s ease;
}

.fade-in-stagger.visible {
    opacity: 1;
    transform: translateY(0);
}

/* ---------- Responsive Timeline ---------- */
@media (max-width: 768px) {
    .timeline { padding-left: 1.5rem; }
    .timeline-item { padding-left: 1rem; }
    .timeline-marker { left: -1.5rem; }
}

/* ==============================================
   v4.0 â€“ Advanced Enhancements
   ============================================== */

/* ---------- Theme Variables ---------- */
body[data-theme="green"] {
    --blue:       #00ff41;
    --blue-dim:   #00cc33;
    --blue-dark:  #002200;
    --green:      #00ff41;
    --green-dim:  #00cc33;
    --green-dark: #002200;
    --cyan:       #00ff41;
    --border-h:   rgba(0, 255, 65, 0.35);
    --text:       #c8c8c8;
    --text-dim:   #505050;
}

body[data-theme="red"] {
    --blue:       #ff5555;
    --blue-dim:   #cc3333;
    --blue-dark:  #220000;
    --green:      #ff5555;
    --green-dim:  #cc3333;
    --green-dark: #220000;
    --cyan:       #ff5555;
    --border-h:   rgba(255, 85, 85, 0.35);
    --text:       #c8c8c8;
    --text-dim:   #505050;
}

/* ---------- Theme Toggle ---------- */
.theme-toggle {
    cursor: pointer;
    padding: 0.3rem 0.5rem;
    border: none;
    transition: color var(--transition);
    user-select: none;
    margin-right: 0.5rem;
}

.theme-toggle:hover {
    color: var(--blue);
}

.theme-icon {
    font-size: 0.85rem;
}

/* ---------- Toast Notifications ---------- */
.toast-container {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    z-index: 10000;
    display: flex;
    flex-direction: column-reverse;
    gap: 0.5rem;
    pointer-events: none;
}

.toast {
    pointer-events: all;
    padding: 0.6rem 1rem;
    border: none;
    border-left: 2px solid var(--blue);
    background: #0a0a0a;
    color: var(--text);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    animation: toast-in 0.3s ease, toast-out 0.3s ease 3s forwards;
    max-width: 320px;
}

.toast.success { border-left-color: var(--blue); }
.toast.error { border-left-color: #ff5555; color: #fff; }
.toast.info { border-left-color: var(--blue); color: var(--blue); }

.toast::before {
    margin-right: 0.5rem;
    font-weight: bold;
}
.toast.success::before { content: '[âœ“]'; }
.toast.error::before { content: '[âœ—]'; }
.toast.info::before { content: '[i]'; }

@keyframes toast-in {
    from { opacity: 0; transform: translateX(100px); }
    to { opacity: 1; transform: translateX(0); }
}

@keyframes toast-out {
    from { opacity: 1; transform: translateX(0); }
    to { opacity: 0; transform: translateX(100px); }
}

/* ---------- Command Palette ---------- */
.cmd-palette-overlay {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(5px);
    display: none;
    align-items: flex-start;
    justify-content: center;
    padding-top: 15vh;
}

.cmd-palette-overlay.active {
    display: flex;
}

.cmd-palette {
    width: 90%;
    max-width: 520px;
    background: #000;
    border: 1px solid #222;
    border-radius: 0;
    overflow: hidden;
    animation: palette-in 0.15s ease;
}

@keyframes palette-in {
    from { opacity: 0; transform: translateY(-20px) scale(0.95); }
    to { opacity: 1; transform: translateY(0) scale(1); }
}

.cmd-palette-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.85rem 1rem;
    border-bottom: 1px solid #222;
}

.cmd-palette-header .prompt {
    color: var(--green);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    white-space: nowrap;
}

.cmd-palette-input {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    color: var(--green);
    font-family: var(--font-mono);
    font-size: 0.9rem;
    caret-color: var(--green);
}

.cmd-palette-input::placeholder {
    color: var(--dim);
}

.cmd-palette-results {
    max-height: 300px;
    overflow-y: auto;
    list-style: none;
    padding: 0.5rem;
    margin: 0;
}

.cmd-palette-results li {
    padding: 0.6rem 0.85rem;
    border-radius: 4px;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--text);
    transition: background 0.15s;
}

.cmd-palette-results li:hover,
.cmd-palette-results li.active {
    background: var(--green-low);
    color: var(--green);
}

.cmd-palette-results li .cmd-icon {
    font-size: 1rem;
    width: 1.5rem;
    text-align: center;
}

.cmd-palette-results li .cmd-label {
    flex: 1;
}

.cmd-palette-results li .cmd-shortcut {
    color: var(--dim);
    font-size: 0.7rem;
}

.cmd-palette-footer {
    padding: 0.5rem 1rem;
    border-top: 1px solid #222;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--dim);
    text-align: center;
}

.kbd {
    display: inline-block;
    padding: 0.1rem 0.3rem;
    border: none;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    background: transparent;
    color: var(--blue);
}

/* ---------- Skill Radar Chart ---------- */
.radar-section {
    margin-top: 3rem;
    text-align: center;
}

.radar-title {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--dim);
    margin-bottom: 1.5rem;
    letter-spacing: 2px;
}

.radar-wrap {
    display: flex;
    justify-content: center;
    padding: 1rem;
}

#skill-radar {
    max-width: 400px;
    width: 100%;
    height: auto;
}

/* ---------- Interactive Live Terminal ---------- */
.live-terminal {
    max-width: 700px;
    margin: 0 auto;
}

.live-terminal-body {
    height: 400px;
    display: flex;
    flex-direction: column;
    padding: 1rem 1.2rem;
}

.live-term-output {
    flex: 1;
    overflow-y: auto;
    padding-bottom: 0.5rem;
}

.live-term-output p {
    margin: 0.2rem 0;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    line-height: 1.6;
    color: var(--text);
}

.live-term-output p.success { color: var(--green); }
.live-term-output p.error { color: #ff073a; }
.live-term-output p.info { color: #00d4ff; }
.live-term-output p.dim { color: var(--dim); }
.live-term-output p.cmd {
    color: var(--green);
    opacity: 0.6;
}

.live-term-output .ascii-art {
    white-space: pre;
    font-size: 0.55rem;
    line-height: 1.2;
    color: var(--green);
}

.live-term-input-line {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding-top: 0.3rem;
    border-top: 1px solid #222;
    flex-shrink: 0;
}

.live-term-input-line .prompt {
    color: var(--green);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    white-space: nowrap;
}

.live-term-input {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    color: var(--green);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    caret-color: var(--green);
}

/* ---------- 3D Tilt Cards ---------- */
.terminal-card.tilt-3d { transform-style: flat; }

.terminal-card .card-glow { display: none; }

/* ---------- Text Decrypt Animation ---------- */
.decrypt-text {
    display: inline-block;
}

.decrypt-text.animating {
    animation: none;
}

/* ---------- Scrollbar Styles ---------- */
.live-terminal-body::-webkit-scrollbar,
.cmd-palette-results::-webkit-scrollbar {
    width: 4px;
}

.live-terminal-body::-webkit-scrollbar-track,
.cmd-palette-results::-webkit-scrollbar-track {
    background: transparent;
}

.live-terminal-body::-webkit-scrollbar-thumb,
.cmd-palette-results::-webkit-scrollbar-thumb {
    background: var(--dim);
    border-radius: 4px;
}

/* ---------- v4 Responsive ---------- */
@media (max-width: 768px) {
    .cmd-palette-overlay { padding-top: 5vh; }
    .cmd-palette { width: 95%; }
    .toast-container { bottom: 1rem; right: 1rem; left: 1rem; }
    .toast { max-width: 100%; }
    #skill-radar { max-width: 280px; }
    .live-terminal-body { height: 300px; }
    .theme-toggle { margin-right: 0.5rem; }
}

@media (max-width: 480px) {
    .project-filters { justify-content: center; }
}

/* ============================================
   v7.0 — Terminal Theme Polish
   ============================================ */

/* ---------- Subtle CRT flicker ---------- */
@keyframes crt-flicker {
    0%   { opacity: 1; }
    87%  { opacity: 1; }
    88%  { opacity: 0.985; }
    89%  { opacity: 1; }
    92%  { opacity: 1; }
    93%  { opacity: 0.97; }
    94%  { opacity: 1; }
    95%  { opacity: 0.98; }
    96%  { opacity: 1; }
    100% { opacity: 1; }
}

body {
    animation: crt-flicker 6s infinite;
}

/* ---------- Section Divider Hover ---------- */
.section-divider {
    transition: color 0.5s ease;
}

.section-divider:hover {
    color: #333;
}

.section-divider:hover::before {
    background: radial-gradient(ellipse, rgba(82,148,226,0.12) 0%, transparent 70%);
}

/* ---------- Enhanced link styles ---------- */
.card-header a,
.timeline-title a {
    color: var(--blue);
    transition: color 0.15s;
}

.card-header a:hover,
.timeline-title a:hover {
    color: #fff;
}

/* ---------- Form focus glow ---------- */
.form-input:focus {
    border-bottom-color: var(--blue);
    caret-color: var(--blue);
}

.live-term-input:focus {
    caret-color: var(--blue);
}

/* ---------- Stat card terminal style ---------- */
.stat-card::before {
    content: '> ';
    color: var(--blue);
    font-size: 0.8rem;
}

/* ---------- Cert badge separator ---------- */
.cert-badge::before {
    content: '[';
    color: #333;
}
.cert-badge::after {
    content: ']';
    color: #333;
}

/* ---------- Smoother section padding ---------- */
@media (max-width: 768px) {
    .section { padding: 3rem 0; }
    .section-divider { font-size: 0.4rem; }
}

/* ---------- Timeline enhanced ---------- */
.timeline-item {
    transition: opacity 0.3s;
}

.timeline-item:hover {
    opacity: 1;
}

.timeline-item:not(:hover) ~ .timeline-item {
    opacity: 0.7;
}

.timeline:hover .timeline-item:not(:hover) {
    opacity: 0.5;
}

.timeline:hover .timeline-item:hover {
    opacity: 1;
}

/* ---------- Project card hover accent ---------- */
.project-card:hover .project-title {
    color: #fff;
}

.project-card:hover .project-desc {
    color: var(--text);
}

/* ---------- Scroll progress bar ---------- */
.scroll-progress {
    position: fixed;
    top: var(--nav-h);
    left: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--blue-dim), var(--blue), var(--blue-dim));
    z-index: 1001;
    width: 0%;
    transition: width 0.1s linear;
    box-shadow: 0 0 8px rgba(82,148,226,0.3);
}

/* ---------- Hero ambient glow ---------- */
.hero::before {
    content: '';
    position: absolute;
    top: 30%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(82,148,226,0.04) 0%, transparent 60%);
    pointer-events: none;
    z-index: -1;
}

/* ---------- Skill fill glow ---------- */
.skill-fill::after {
    content: '';
    position: absolute;
    right: 0;
    top: -2px;
    width: 6px;
    height: 10px;
    background: var(--blue);
    box-shadow: 0 0 6px rgba(82,148,226,0.5);
    border-radius: 1px;
}

/* ---------- Project card hover glow ---------- */
.project-card:hover {
    border-left-color: var(--blue);
    box-shadow: -4px 0 12px -6px rgba(82,148,226,0.15);
}

/* ---------- Timeline dot glow ---------- */
.timeline-item:hover .timeline-dot {
    background: #fff;
    box-shadow: 0 0 8px rgba(82,148,226,0.4);
}

/* ---------- Active nav link glow ---------- */
.nav-link.active {
    text-shadow: 0 0 10px rgba(82,148,226,0.3);
}

/* ---------- Status dot glow ---------- */
.status-dot {
    box-shadow: 0 0 6px rgba(82,148,226,0.4);
}

/* ---------- Footer top border glow ---------- */
.footer {
    border-top: 1px solid #1a1a1a;
}

.footer::before {
    content: '';
    position: absolute;
    top: -1px;
    left: 50%;
    transform: translateX(-50%);
    width: 300px;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(82,148,226,0.15), transparent);
}

/* ---------- Radar section background ---------- */
.radar-section {
    position: relative;
}

.radar-section::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 350px;
    height: 350px;
    background: radial-gradient(circle, rgba(82,148,226,0.03) 0%, transparent 60%);
    pointer-events: none;
}

/* ---------- Smooth hover on all interactive ---------- */
.filter-btn,
.proj-link,
.tool-tag,
.cert-badge,
.nav-link,
.lang-opt {
    transition: color 0.2s ease;
}

/* ---------- Better form textarea ---------- */
.form-textarea {
    min-height: 120px;
    resize: vertical;
    border-bottom: 1px solid #222;
}

.form-textarea:focus {
    border-bottom-color: var(--blue);
}

/* ============================================
   v10.0 — Advanced Micro-Interactions
   ============================================ */

/* ---------- Animated Timeline Draw Line ---------- */
.timeline-draw-line {
    position: absolute;
    left: 8px;
    top: 0;
    width: 1px;
    height: 0;
    background: linear-gradient(180deg, var(--blue), rgba(82,148,226,0.2));
    z-index: 3;
    transition: height 0.1s linear;
    box-shadow: 0 0 6px rgba(82,148,226,0.3);
}

/* ---------- Floating Particles ---------- */
.floating-particles {
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 100%;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
}

.float-char {
    position: absolute;
    bottom: -30px;
    color: var(--blue);
    font-family: var(--font-mono);
    animation: float-up linear infinite;
    pointer-events: none;
    user-select: none;
}

@keyframes float-up {
    0% {
        transform: translateY(0) rotate(0deg);
        opacity: 0;
    }
    10% {
        opacity: 0.06;
    }
    90% {
        opacity: 0.04;
    }
    100% {
        transform: translateY(-110vh) rotate(360deg);
        opacity: 0;
    }
}

/* ---------- Mouse Glow Follower ---------- */
.mouse-glow {
    position: fixed;
    width: 300px;
    height: 300px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(82,148,226,0.03) 0%, transparent 60%);
    pointer-events: none;
    z-index: 1;
    transform: translate(-50%, -50%);
    will-change: left, top;
}

/* ---------- Section Scroll Indicator ---------- */
.section-indicator {
    position: fixed;
    right: 1.2rem;
    top: 50%;
    transform: translateY(-50%);
    z-index: 100;
    display: flex;
    flex-direction: column;
    gap: 8px;
}

.si-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #1a1a1a;
    cursor: pointer;
    transition: all 0.3s ease;
    border: 1px solid transparent;
}

.si-dot:hover {
    background: #333;
    transform: scale(1.5);
}

.si-dot.active {
    background: var(--blue);
    box-shadow: 0 0 6px rgba(82,148,226,0.4);
    transform: scale(1.3);
}

@media (max-width: 768px) {
    .section-indicator { display: none; }
    .mouse-glow { display: none; }
    .floating-particles { display: none; }
}

/* ---------- Project card scan sweep ---------- */
.project-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(82,148,226,0.03), transparent);
    transition: left 0.6s ease;
    pointer-events: none;
    z-index: -1;
}

.project-card {
    position: relative;
    overflow: hidden;
}

.project-card:hover::before {
    left: 100%;
}

/* ---------- Skill bar pulse glow ---------- */
@keyframes skill-pulse {
    0%, 100% { box-shadow: 0 0 4px rgba(82,148,226,0.2); }
    50%      { box-shadow: 0 0 10px rgba(82,148,226,0.5); }
}

.skill-fill.visible {
    animation: skill-pulse 2s ease-in-out infinite;
    animation-delay: 1.5s;
}

/* ---------- Hero button hover pulse ---------- */
.btn-primary:hover {
    color: #fff;
    text-shadow: 0 0 8px rgba(82,148,226,0.4);
}

.btn-secondary:hover {
    color: var(--blue);
    text-shadow: 0 0 6px rgba(82,148,226,0.2);
}

/* ---------- Link underline animation (card body links) ---------- */
.card-body a {
    position: relative;
    color: var(--blue);
}

.card-body a::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--blue);
    transition: width 0.3s ease;
}

.card-body a:hover::after {
    width: 100%;
}

/* ---------- Tool tag hover highlight ---------- */
.tool-tag:hover {
    color: var(--blue);
    text-shadow: 0 0 6px rgba(82,148,226,0.2);
}

/* ---------- Contact JSON hover effect ---------- */
.json-indent:hover .json-val {
    color: var(--blue);
}

.json-indent {
    transition: padding-left 0.2s ease;
}

.json-indent:hover {
    padding-left: 2rem;
}

/* ---------- Footer heartbeat pulse ---------- */
@keyframes heartbeat {
    0%, 100% { transform: scale(1); }
    50%      { transform: scale(1.15); }
}

.footer-copy .heart {
    display: inline-block;
    animation: heartbeat 1.5s ease-in-out infinite;
}

/* ---------- Section number glow ---------- */
.section-num {
    text-shadow: 0 0 12px rgba(82,148,226,0.15);
    transition: text-shadow 0.3s ease;
}

.section-header:hover .section-num {
    text-shadow: 0 0 16px rgba(82,148,226,0.4);
}

/* ---------- Timeline item slide-in ---------- */
.timeline-item.fade-in {
    transform: translateX(-20px);
    opacity: 0;
}

.timeline-item.fade-in.visible {
    transform: translateX(0);
    opacity: 1;
}

/* ---------- Cert badge hover ---------- */
.cert-badge:hover {
    color: #fff;
    text-shadow: 0 0 8px rgba(82,148,226,0.3);
}

/* ---------- Smooth focus ring for a11y ---------- */
.form-input:focus-visible,
.live-term-input:focus-visible,
.cmd-palette-input:focus-visible {
    outline: 1px solid rgba(82,148,226,0.3);
    outline-offset: 2px;
}

/* ---------- Back-to-top enhanced ---------- */
.back-to-top:hover {
    color: #fff;
    text-shadow: 0 0 8px rgba(82,148,226,0.3);
    transform: translateY(-3px);
}

/* ---------- Noise texture overlay ---------- */
body::after {
    content: '';
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 100%;
    z-index: 9997;
    pointer-events: none;
    opacity: 0.015;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-repeat: repeat;
    background-size: 256px 256px;
}

/* ---------- Typing cursor enhanced ---------- */
@keyframes cursor-breathe {
    0%, 100% { opacity: 1; }
    40%      { opacity: 1; }
    50%      { opacity: 0; }
    90%      { opacity: 0; }
}

.cursor-blink {
    animation: cursor-breathe 1.2s ease infinite;
}

/* ---------- Nav link count badge ---------- */
.nav-link[href="#projects"]::before {
    content: '';
}

/* ---------- Smooth page load ---------- */
@keyframes page-load {
    from { opacity: 0; }
    to   { opacity: 1; }
}

body {
    animation: page-load 0.5s ease, crt-flicker 6s infinite;
    animation-delay: 0s, 0.5s;
}

    <div class="section-divider" aria-hidden="true">─────────────────────────────────────────────────────────────────────────────────────</div>

    <!-- Contact Section -->
    <section id="contact" class="section">
        <div class="container">
            <div class="section-header">
                <span class="section-num">07.</span>
                <h2 class="section-title"><span data-i18n="sec_contact"></span><span class="cursor-blink">_</span></h2>
                <div class="section-line"></div>
            </div>
            <div class="contact-grid">
                <div class="contact-info">
                    <div class="terminal-card">
                        <div class="card-header">
                            <span class="card-icon">$</span> cat contact.json
                        </div>
                        <div class="card-body contact-json">
                            <p><span class="json-brace">{</span></p>
                            <p class="json-indent">
                                <span class="json-key">"email"</span>:
                                <span class="json-val">"<a href="mailto:omerburaka95@gmail.com">omerburaka95@gmail.com</a>"</span>,
                            </p>
                            <p class="json-indent">
                                <span class="json-key">"github"</span>:
                                <span class="json-val">"<a href="https://github.com/somestr" target="_blank" rel="noopener noreferrer">github.com/somestr</a>"</span>,
                            </p>
                            <p class="json-indent">
                                <span class="json-key">"linkedin"</span>:
                                <span class="json-val">"<a href="https://linkedin.com/in/omerburaka/" target="_blank" rel="noopener noreferrer">linkedin.com/in/omerburaka</a>"</span>,
                            </p>
                            <p class="json-indent">
                                <span class="json-key">"tryhackme"</span>:
                                <span class="json-val">"<a href="https://tryhackme.com/p/somestr" target="_blank" rel="noopener noreferrer">tryhackme.com/p/somestr</a>"</span>,
                            </p>
                            <p class="json-indent">
                                <span class="json-key">"location"</span>:
                                <span class="json-val">"Dublin, Ireland"</span>,
                            </p>
                            <p class="json-indent">
                                <span class="json-key">"status"</span>:
                                <span class="json-val success" data-i18n="contact_status"></span>
                            </p>
                            <p><span class="json-brace">}</span></p>
                        </div>
                    </div>
                    <!-- Live Server Status -->
                    <div class="terminal-card server-status-card">
                        <div class="card-header">
                            <span class="card-icon">$</span> uptime
                        </div>
                        <div class="card-body">
                            <p class="server-stat"><span class="key">SERVER :</span> <span class="val success" id="server-status">● ONLINE</span></p>
                            <p class="server-stat"><span class="key">UPTIME :</span> <span class="val" id="server-uptime">--</span></p>
                            <p class="server-stat"><span class="key" data-i18n="visitors_label"></span> <span class="val" id="visitor-count">--</span></p>
                        </div>
                    </div>
                </div>
                <div class="contact-form">
                    <div class="terminal-card">
                        <div class="card-header">
                            <span class="card-icon">$</span> ./send_message.sh
                        </div>
                        <div class="card-body">
                            <form id="contact-form" novalidate>
                                <div class="form-group">
                                    <label class="form-label" for="form-name">
                                        <span class="prompt-mini">input@user:~$</span> <span data-i18n="form_name"></span>
                                    </label>
                                    <input type="text" class="form-input" id="form-name" data-i18n-ph="ph_name" placeholder="" autocomplete="name" required maxlength="100">
                                </div>
                                <div class="form-group">
                                    <label class="form-label" for="form-email">
                                        <span class="prompt-mini">input@user:~$</span> <span data-i18n="form_email"></span>
                                    </label>
                                    <input type="email" class="form-input" id="form-email" data-i18n-ph="ph_email" placeholder="" autocomplete="email" required maxlength="200">
                                </div>
                                <div class="form-group">
                                    <label class="form-label" for="form-message">
                                        <span class="prompt-mini">input@user:~$</span> <span data-i18n="form_message"></span>
                                    </label>
                                    <textarea class="form-input form-textarea" id="form-message" data-i18n-ph="ph_message" placeholder="" required maxlength="2000"></textarea>
                                </div>
                                <button type="submit" class="btn-submit cyber-btn" id="form-submit">
                                    <span id="submit-text" data-i18n="form_send"></span>
                                </button>
                                <div id="form-status" class="form-status" style="display:none"></div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Back to Top -->
    <button class="back-to-top" id="back-to-top" aria-label="Back to top">
        <span>▲</span>
        <span class="btt-text">TOP</span>
    </button>

    <!-- Footer -->
    <footer class="footer">
        <div class="footer-content">
            <p class="footer-text">
                <span class="prompt">root@portfolio:~$</span>
                echo "<span data-i18n="footer_echo"></span>"
            </p>
            <p class="footer-copy">&copy; 2026 Ömer Burak Akçınar | <span data-i18n="footer_title"></span> | v4.2.0</p>
        </div>
        <div class="footer-ascii">
<pre>
  ┌─────────────────────────────────────────┐
  │  root@oba-sec:~# exit                  │
  │  Connection to portfolio closed.        │
  └─────────────────────────────────────────┘
</pre>
        </div>
    </footer>

    <script src="i18n.js?v=4.2"></script>
    <script src="script.js?v=10.0"></script>
</body>

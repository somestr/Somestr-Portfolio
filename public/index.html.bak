<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>[ OBA ] :: Ömer Burak Akçınar — IT & Cybersecurity Portfolio</title>

    <!-- SEO Meta Tags -->
    <meta name="description" content="Ömer Burak Akçınar — IT and cybersecurity professional. Incident response, threat detection, vulnerability assessment, end-user support.">
    <meta name="keywords" content="cybersecurity, IT support, incident response, threat detection, vulnerability assessment, Ömer Burak Akçınar, Dublin, Ireland">
    <meta name="author" content="Ömer Burak Akçınar">
    <meta name="robots" content="index, follow">
    <meta name="theme-color" content="#000000">

    <!-- Open Graph / Social -->
    <meta property="og:type" content="website">
    <meta property="og:title" content="Ömer Burak Akçınar — IT & Cybersecurity Portfolio">
    <meta property="og:description" content="IT and Cybersecurity Professional — Incident Response, Threat Detection, Vulnerability Assessment">
    <meta property="og:locale" content="tr_TR">
    <meta property="og:locale:alternate" content="en_US">
    <meta property="og:locale:alternate" content="ko_KR">

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="Ömer Burak Akçınar — IT & Cybersecurity Portfolio">
    <meta name="twitter:description" content="IT and Cybersecurity Professional — Incident Response, Threat Detection, Vulnerability Assessment">

    <link rel="stylesheet" href="style.css?v=10.0">
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🛡️</text></svg>">
</head>
<body>

    <!-- Scanlines overlay -->
    <div class="scanlines"></div>

    <!-- Vignette overlay -->
    <div class="vignette"></div>

    <!-- Matrix Rain Canvas -->
    <canvas id="matrix-canvas"></canvas>

    <!-- Toast Container -->
    <div class="toast-container" id="toast-container"></div>

    <!-- Command Palette -->
    <div class="cmd-palette-overlay" id="cmd-palette-overlay">
        <div class="cmd-palette">
            <div class="cmd-palette-header">
                <span class="prompt">root@kali:~$</span>
                <input type="text" class="cmd-palette-input" id="cmd-palette-input" placeholder="Type a command..." autocomplete="off" spellcheck="false">
            </div>
            <ul class="cmd-palette-results" id="cmd-palette-results"></ul>
            <div class="cmd-palette-footer">
                <span class="kbd">↑↓</span> navigate &nbsp; <span class="kbd">↵</span> select &nbsp; <span class="kbd">esc</span> close
            </div>
        </div>
    </div>

    <!-- Terminal Intro Screen -->
    <div class="intro-overlay" id="intro-overlay">
        <div class="kali-screen" id="intro-body"></div>
    </div>

    <!-- Scroll Progress -->
    <div class="scroll-progress" id="scroll-progress"></div>

    <!-- Navigation -->
    <nav class="terminal-nav" id="main-nav">
        <div class="nav-logo">
            <span class="bracket">[</span>
            <span class="logo-text" id="logo-type"></span>
            <span class="cursor-blink">_</span>
            <span class="bracket">]</span>
        </div>
        <button class="mobile-menu-btn" id="mobile-menu-btn" aria-label="Menu">
            <span></span><span></span><span></span>
        </button>
        <ul class="nav-links" id="nav-links">
            <li><a href="#home"       class="nav-link">~</a></li>
            <li><a href="#terminal"   class="nav-link" data-i18n="nav_terminal"></a></li>
            <li><a href="#about"      class="nav-link" data-i18n="nav_about"></a></li>
            <li><a href="#experience" class="nav-link" data-i18n="nav_experience"></a></li>
            <li><a href="#skills"     class="nav-link" data-i18n="nav_skills"></a></li>
            <li><a href="#education"  class="nav-link" data-i18n="nav_education"></a></li>
            <li><a href="#projects"   class="nav-link" data-i18n="nav_projects"></a></li>
            <li><a href="#contact"    class="nav-link" data-i18n="nav_contact"></a></li>
        </ul>
        <div class="nav-right">
            <div class="theme-toggle" id="theme-toggle" title="Switch Theme">
                <span class="theme-icon" id="theme-icon">�</span>
            </div>
            <div class="lang-toggle" id="lang-toggle" title="Switch Language">
                <span class="lang-opt" id="lang-tr">TR</span>
                <span class="lang-sep">/</span>
                <span class="lang-opt" id="lang-en">EN</span>
                <span class="lang-sep">/</span>
                <span class="lang-opt" id="lang-ko">KO</span>
            </div>
            <div class="nav-status">
                <span class="status-dot"></span>
                <span class="status-text" data-i18n="status_active"></span>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <section id="home" class="hero">
        <div class="hero-content">
            <div class="terminal-window">
                <div class="terminal-titlebar">
                    <span class="tb-btn tb-close"></span>
                    <span class="tb-btn tb-min"></span>
                    <span class="tb-btn tb-max"></span>
                    <span class="tb-title">root@portfolio:~$ <span class="tb-cursor">▋</span></span>
                </div>
                <div class="terminal-body">
                    <div class="term-line">
                        <span class="prompt">root@kali:~$</span>
                        <span class="cmd" id="cmd1"></span>
                    </div>
                    <div class="term-output" id="output1" style="display:none">
                        <div class="output-block">
                            <p><span class="key" data-i18n="hero_name_label"></span> <span class="val" id="hero-name">Ömer Burak Akçınar</span></p>
                            <p><span class="key" data-i18n="hero_role_label"></span> <span class="val" data-i18n="hero_role_val"></span></p>
                            <p><span class="key" data-i18n="hero_status_label"></span> <span class="val success" data-i18n="hero_status_val"></span></p>
                            <p><span class="key" data-i18n="hero_location_label"></span> <span class="val" data-i18n="hero_location_val"></span></p>
                        </div>
                    </div>
                    <div class="term-line" id="line2" style="display:none">
                        <span class="prompt">root@kali:~$</span>
                        <span class="cmd" id="cmd2"></span>
                    </div>
                    <div class="term-output" id="output2" style="display:none">
                        <p class="warn"    data-i18n="hero_warn"></p>
                        <p class="success" data-i18n="hero_auth"></p>
                        <p class="info"    data-i18n="hero_load"></p>
                        <div class="progress-bar-wrap">
                            <div class="progress-bar" id="hero-progress"></div>
                            <span class="progress-pct" id="hero-pct">0%</span>
                        </div>
                    </div>
                    <div class="term-line" id="line3" style="display:none">
                        <span class="prompt">root@kali:~$</span>
                        <span class="blink-cursor">▋</span>
                    </div>
                </div>
            </div>
            <div class="hero-cta" id="hero-cta" style="display:none">
                <a href="#about"   class="btn-primary cyber-btn"   data-i18n="cta_enter"></a>
                <a href="#contact" class="btn-secondary cyber-btn" data-i18n="cta_contact"></a>
                <a href="#" class="btn-secondary cyber-btn" id="cv-download" data-i18n="cta_cv"></a>
            </div>
        </div>
        <div class="scroll-hint">
            <span class="scroll-arrow">▼</span>
            <span data-i18n="scroll_hint"></span>
        </div>
    </section>

    <div class="section-divider" aria-hidden="true">─────────────────────────────────────────────────────────────────────────────────────</div>

    <!-- Interactive Terminal -->
    <section id="terminal" class="section section-dark">
        <div class="container">
            <div class="section-header">
                <span class="section-num">01.</span>
                <h2 class="section-title"><span data-i18n="sec_terminal"></span><span class="cursor-blink">_</span></h2>
                <div class="section-line"></div>
            </div>
            <div class="live-terminal">
                <div class="terminal-window">
                    <div class="terminal-titlebar">
                        <span class="tb-btn tb-close"></span>
                        <span class="tb-btn tb-min"></span>
                        <span class="tb-btn tb-max"></span>
                        <span class="tb-title">visitor@oba_sec:~$ <span data-i18n="terminal_hint"></span></span>
                    </div>
                    <div class="live-terminal-body" id="live-terminal-body">
                        <div class="live-term-output" id="live-term-output">
                            <p class="success" data-i18n="terminal_welcome"></p>
                            <p class="info" data-i18n="terminal_help_hint"></p>
                        </div>
                        <div class="live-term-input-line">
                            <span class="prompt">visitor@oba_sec:~$</span>
                            <input type="text" class="live-term-input" id="live-term-input" spellcheck="false" autocomplete="off">
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <div class="section-divider" aria-hidden="true">─────────────────────────────────────────────────────────────────────────────────────</div>

    <!-- About Section -->
    <section id="about" class="section">
        <div class="container">
            <div class="section-header">
                <span class="section-num">02.</span>
                <h2 class="section-title"><span data-i18n="sec_about"></span><span class="cursor-blink">_</span></h2>
                <div class="section-line"></div>
            </div>
            <div class="about-grid">
                <div class="about-text">
                    <div class="terminal-card">
                        <div class="card-header">
                            <span class="card-icon">$</span> cat /etc/profile.txt
                        </div>
                        <div class="card-body">
                            <p data-i18n="about_p1"></p>
                            <br>
                            <p data-i18n="about_p2"></p>
                            <br>
                            <p data-i18n="about_p3"></p>
                        </div>
                    </div>
                </div>
                <div class="about-stats">
                    <div class="stat-card">
                        <span class="stat-num" data-target="10">0</span>
                        <span class="stat-label" data-i18n="stat_projects"></span>
                    </div>
                    <div class="stat-card">
                        <span class="stat-num" data-target="4">0</span>
                        <span class="stat-label" data-i18n="stat_certs"></span>
                    </div>
                    <div class="stat-card">
                        <span class="stat-num" data-target="9">0</span>
                        <span class="stat-label" data-i18n="stat_exp"></span>
                    </div>
                    <div class="stat-card">
                        <span class="stat-num" data-target="2">0</span>
                        <span class="stat-label" data-i18n="stat_edu"></span>
                    </div>
                    <div class="cert-list">
                        <p class="cert-title">// <span data-i18n="certs_title"></span></p>
                        <span class="cert-badge">CompTIA A+</span>
                        <span class="cert-badge">Cisco CyberSec</span>
                        <span class="cert-badge">CyberTakeOff</span>
                        <span class="cert-badge pursuing">Security+ ⏳</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <div class="section-divider" aria-hidden="true">─────────────────────────────────────────────────────────────────────────────────────</div>

    <!-- Experience / Timeline Section -->
    <section id="experience" class="section section-dark">
        <div class="container">
            <div class="section-header">
                <span class="section-num">03.</span>
                <h2 class="section-title"><span data-i18n="sec_experience"></span><span class="cursor-blink">_</span></h2>
                <div class="section-line"></div>
            </div>
            <div class="timeline">
                <div class="timeline-item">
                    <div class="timeline-marker"><span class="timeline-dot"></span></div>
                    <div class="timeline-content terminal-card">
                        <div class="card-header">
                            <span class="card-icon">$</span> <span data-i18n="exp1_date"></span>
                        </div>
                        <div class="card-body">
                            <h3 class="timeline-title" data-i18n="exp1_title"></h3>
                            <p class="timeline-company" data-i18n="exp1_company"></p>
                            <p class="timeline-desc" data-i18n="exp1_desc"></p>
                            <div class="timeline-tags">
                                <span class="p-tag">Customer Service</span>
                                <span class="p-tag">Operations</span>
                                <span class="p-tag">Teamwork</span>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="timeline-item">
                    <div class="timeline-marker"><span class="timeline-dot"></span></div>
                    <div class="timeline-content terminal-card">
                        <div class="card-header">
                            <span class="card-icon">$</span> <span data-i18n="exp2_date"></span>
                        </div>
                        <div class="card-body">
                            <h3 class="timeline-title" data-i18n="exp2_title"></h3>
                            <p class="timeline-company" data-i18n="exp2_company"></p>
                            <p class="timeline-desc" data-i18n="exp2_desc"></p>
                            <div class="timeline-tags">
                                <span class="p-tag">Team Leadership</span>
                                <span class="p-tag">Duty Manager</span>
                                <span class="p-tag">Operations</span>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="timeline-item">
                    <div class="timeline-marker"><span class="timeline-dot"></span></div>
                    <div class="timeline-content terminal-card">
                        <div class="card-header">
                            <span class="card-icon">$</span> <span data-i18n="exp3_date"></span>
                        </div>
                        <div class="card-body">
                            <h3 class="timeline-title" data-i18n="exp3_title"></h3>
                            <p class="timeline-company" data-i18n="exp3_company"></p>
                            <p class="timeline-desc" data-i18n="exp3_desc"></p>
                            <div class="timeline-tags">
                                <span class="p-tag">Incident Response</span>
                                <span class="p-tag">Vulnerability Assessment</span>
                                <span class="p-tag">Phishing</span>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="timeline-item">
                    <div class="timeline-marker"><span class="timeline-dot"></span></div>
                    <div class="timeline-content terminal-card">
                        <div class="card-header">
                            <span class="card-icon">$</span> <span data-i18n="exp4_date"></span>
                        </div>
                        <div class="card-body">
                            <h3 class="timeline-title" data-i18n="exp4_title"></h3>
                            <p class="timeline-company" data-i18n="exp4_company"></p>
                            <p class="timeline-desc" data-i18n="exp4_desc"></p>
                            <div class="timeline-tags">
                                <span class="p-tag">Hardware</span>
                                <span class="p-tag">Networking</span>
                                <span class="p-tag">End-User Support</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <div class="section-divider" aria-hidden="true">─────────────────────────────────────────────────────────────────────────────────────</div>

    <!-- Skills Section -->
    <section id="skills" class="section">
        <div class="container">
            <div class="section-header">
                <span class="section-num">04.</span>
                <h2 class="section-title"><span data-i18n="sec_skills"></span><span class="cursor-blink">_</span></h2>
                <div class="section-line"></div>
            </div>
            <div class="skills-grid">
                <div class="skill-category">
                    <h3 class="skill-cat-title">
                        <span class="cat-icon">🖥</span> <span data-i18n="skills_systems"></span>
                    </h3>
                    <div class="skill-item">
                        <div class="skill-info"><span data-i18n="skill_windows"></span><span class="skill-pct">90%</span></div>
                        <div class="skill-bar"><div class="skill-fill" data-width="90"></div></div>
                    </div>
                    <div class="skill-item">
                        <div class="skill-info"><span data-i18n="skill_linux"></span><span class="skill-pct">85%</span></div>
                        <div class="skill-bar"><div class="skill-fill" data-width="85"></div></div>
                    </div>
                    <div class="skill-item">
                        <div class="skill-info"><span data-i18n="skill_ad"></span><span class="skill-pct">75%</span></div>
                        <div class="skill-bar"><div class="skill-fill" data-width="75"></div></div>
                    </div>
                    <div class="skill-item">
                        <div class="skill-info"><span data-i18n="skill_networking"></span><span class="skill-pct">80%</span></div>
                        <div class="skill-bar"><div class="skill-fill" data-width="80"></div></div>
                    </div>
                </div>
                <div class="skill-category">
                    <h3 class="skill-cat-title">
                        <span class="cat-icon">🛡</span> <span data-i18n="skills_security"></span>
                    </h3>
                    <div class="skill-item">
                        <div class="skill-info"><span data-i18n="skill_ir"></span><span class="skill-pct">80%</span></div>
                        <div class="skill-bar"><div class="skill-fill" data-width="80"></div></div>
                    </div>
                    <div class="skill-item">
                        <div class="skill-info"><span data-i18n="skill_threat"></span><span class="skill-pct">75%</span></div>
                        <div class="skill-bar"><div class="skill-fill" data-width="75"></div></div>
                    </div>
                    <div class="skill-item">
                        <div class="skill-info"><span data-i18n="skill_vuln"></span><span class="skill-pct">78%</span></div>
                        <div class="skill-bar"><div class="skill-fill" data-width="78"></div></div>
                    </div>
                    <div class="skill-item">
                        <div class="skill-info"><span data-i18n="skill_support"></span><span class="skill-pct">92%</span></div>
                        <div class="skill-bar"><div class="skill-fill" data-width="92"></div></div>
                    </div>
                </div>
                <div class="skill-category">
                    <h3 class="skill-cat-title">
                        <span class="cat-icon">&lt;/&gt;</span> <span data-i18n="skills_tools"></span>
                    </h3>
                    <div class="tools-grid">
                        <span class="tool-tag">Windows</span>
                        <span class="tool-tag">Linux</span>
                        <span class="tool-tag">Kali Linux</span>
                        <span class="tool-tag">Active Directory</span>
                        <span class="tool-tag">Wireshark</span>
                        <span class="tool-tag">Nmap</span>
                        <span class="tool-tag">Microsoft 365</span>
                        <span class="tool-tag">DNS / DHCP</span>
                        <span class="tool-tag">VPN</span>
                        <span class="tool-tag">PowerShell</span>
                        <span class="tool-tag">Bash</span>
                        <span class="tool-tag">Git</span>
                    </div>
                </div>
            </div>

            <!-- Skill Radar Chart -->
            <div class="radar-section">
                <h3 class="radar-title">// <span data-i18n="radar_title"></span></h3>
                <div class="radar-wrap">
                    <canvas id="skill-radar" width="400" height="400"></canvas>
                </div>
            </div>

        </div>
    </section>

    <div class="section-divider" aria-hidden="true">─────────────────────────────────────────────────────────────────────────────────────</div>

    <!-- Education Section -->
    <section id="education" class="section">
        <div class="container">
            <div class="section-header">
                <span class="section-num">05.</span>
                <h2 class="section-title"><span data-i18n="sec_education"></span><span class="cursor-blink">_</span></h2>
                <div class="section-line"></div>
            </div>
            <div class="timeline">
                <div class="timeline-item">
                    <div class="timeline-marker"><span class="timeline-dot"></span></div>
                    <div class="timeline-content terminal-card">
                        <div class="card-header">
                            <span class="card-icon">$</span> 2025
                        </div>
                        <div class="card-body">
                            <h3 class="timeline-title" data-i18n="edu1_title"></h3>
                            <p class="timeline-company" data-i18n="edu1_school"></p>
                            <p class="timeline-desc" data-i18n="edu1_desc"></p>
                        </div>
                    </div>
                </div>
                <div class="timeline-item">
                    <div class="timeline-marker"><span class="timeline-dot"></span></div>
                    <div class="timeline-content terminal-card">
                        <div class="card-header">
                            <span class="card-icon">$</span> <span data-i18n="edu2_year"></span>
                        </div>
                        <div class="card-body">
                            <h3 class="timeline-title" data-i18n="edu2_title"></h3>
                            <p class="timeline-company" data-i18n="edu2_school"></p>
                            <p class="timeline-desc" data-i18n="edu2_desc"></p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <div class="section-divider" aria-hidden="true">─────────────────────────────────────────────────────────────────────────────────────</div>

    <!-- Projects Section -->
    <section id="projects" class="section section-dark">
        <div class="container">
            <div class="section-header">
                <span class="section-num">06.</span>
                <h2 class="section-title"><span data-i18n="sec_projects"></span><span class="cursor-blink">_</span></h2>
                <div class="section-line"></div>
            </div>
            <!-- Project Filters -->
            <div class="project-filters">
                <button class="filter-btn active" data-filter="all" data-i18n="filter_all"></button>
                <button class="filter-btn" data-filter="offense" data-i18n="filter_offense"></button>
                <button class="filter-btn" data-filter="defense" data-i18n="filter_defense"></button>
                <button class="filter-btn" data-filter="tool" data-i18n="filter_tools"></button>
            </div>
            <div class="projects-grid">
                <div class="project-card" data-category="offense">
                    <div class="project-header">
                        <span class="project-icon">🔍</span>
                        <div class="project-links">
                            <a href="#" class="proj-link">[ gh ]</a>
                            <a href="#" class="proj-link">[ demo ]</a>
                        </div>
                    </div>
                    <h3 class="project-title">NetSweep Scanner</h3>
                    <p class="project-desc" data-i18n="proj1_desc"></p>
                    <div class="project-tags">
                        <span class="p-tag">Python</span><span class="p-tag">Nmap</span><span class="p-tag">CVE-DB</span>
                    </div>
                    <div class="project-severity">
                        <span class="sev-label" data-i18n="found_vulns"></span>
                        <span class="sev critical">CRITICAL: 3</span>
                        <span class="sev high">HIGH: 12</span>
                    </div>
                </div>
                <div class="project-card" data-category="offense">
                    <div class="project-header">
                        <span class="project-icon">🕷️</span>
                        <div class="project-links">
                            <a href="#" class="proj-link">[ gh ]</a>
                            <a href="#" class="proj-link">[ demo ]</a>
                        </div>
                    </div>
                    <h3 class="project-title">WebCrawl Pro</h3>
                    <p class="project-desc" data-i18n="proj2_desc"></p>
                    <div class="project-tags">
                        <span class="p-tag">Python</span><span class="p-tag">Selenium</span><span class="p-tag">OWASP</span>
                    </div>
                    <div class="project-severity">
                        <span class="sev-label" data-i18n="found_vulns"></span>
                        <span class="sev critical">CRITICAL: 7</span>
                        <span class="sev high">HIGH: 24</span>
                    </div>
                </div>
                <div class="project-card" data-category="tool">
                    <div class="project-header">
                        <span class="project-icon">🔐</span>
                        <div class="project-links">
                            <a href="#" class="proj-link">[ gh ]</a>
                            <a href="#" class="proj-link">[ demo ]</a>
                        </div>
                    </div>
                    <h3 class="project-title">CryptoVault</h3>
                    <p class="project-desc" data-i18n="proj3_desc"></p>
                    <div class="project-tags">
                        <span class="p-tag">C++</span><span class="p-tag">OpenSSL</span><span class="p-tag">Crypto</span>
                    </div>

# Auto detect text files and perform LF normalization
* text=auto

# Keep source/config files stable across Windows and Linux runners
.gitattributes text eol=lf
*.css text eol=lf
*.html text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.svg text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

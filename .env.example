# Copy this file to .env and fill in the values.
# Never commit your actual .env file.

# Server port (most platforms set this automatically)
PORT=3000

# Set to "production" when deploying
NODE_ENV=development

# Trust proxy setting for platforms behind a reverse proxy
# Values: loopback | linklocal | uniquelocal | 1 | 2 | (leave empty for local dev)
TRUST_PROXY=

# Optional: Discord/Slack webhook URL to receive security event alerts
SECURITY_ALERT_WEBHOOK_URL=

# Optional: override default file paths
# CONTACT_MESSAGES_FILE=/data/messages.json
# SECURITY_EVENTS_FILE=/data/security-events.jsonl
